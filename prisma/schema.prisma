datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "sync"
  recursive_type_depth = 5
}

model User {
  id                  Int      @id @default(autoincrement())
  username            String   @unique
  passwordHash        String
  securityQuestion    String
  securityAnswerHash  String
  createdAt           DateTime @default(now())
}
