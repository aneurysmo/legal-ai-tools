LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR.KEY
DATABASE_URL=file:./app.db

# --- Proveedores adicionales (opcional) ---
# ANTHROPIC_API_KEY=YOUR.KEY
# OPENAI_API_KEY=YOUR.KEY
# DEEPSEEK_API_KEY=YOUR.KEY
# GITHUB_API_KEY=YOUR.GITHUB.TOKEN
# GROQ_API_KEY=YOUR.KEY

# --- Fallback automatico (opcional) ---
# Si el proveedor activo (LLM_PROVIDER, siempre gemini) falla, ask_llm()
# reintenta automaticamente con este proveedor (debe tener su propia clave
# configurada arriba). Util para no interrumpir una demo si un proveedor se
# queda sin cuota. Valores validos: claude, openai, gemini, deepseek, github, groq.
# LLM_FALLBACK_PROVIDER=groq
